<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardTab"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- SNAPSHOT ALANI -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/bg_input">

                <ImageView
                    android:id="@+id/tabSnapshot"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>

                <!-- Snapshot yoksa placeholder -->
                <LinearLayout
                    android:id="@+id/tabPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐"
                        android:textSize="32sp"/>

                    <TextView
                        android:id="@+id/tabPlaceholderDomain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </FrameLayout>

            <!-- ALT BİLGİ SATIRI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="8dp"
                android:background="@color/bg_card">

                <!-- Aktif göstergesi -->
                <View
                    android:id="@+id/tabActiveIndicator"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot_active"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tabDomain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:singleLine="true"/>

                <!-- Kapat butonu -->
                <TextView
                    android:id="@+id/btnCloseTab"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>